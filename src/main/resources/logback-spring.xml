<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Import Spring Boot's default converters: registers %clr, %wEx, etc. -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="OrionETL"/>

    <!-- ============================================================ -->
    <!-- CONSOLE APPENDER — for local and dev profiles                -->
    <!-- Includes MDC context: executionId, pipelineId, stepName      -->
    <!-- ============================================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(%5p){highlight} %clr(${PID:- }){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} [exec=%X{executionId:--}] [pipeline=%X{pipelineId:--}] [step=%X{stepName:--}] %m%n%wEx</pattern>
        </encoder>
    </appender>

    <!-- ============================================================ -->
    <!-- FILE APPENDER — structured output for prod                   -->
    <!-- Uses plain pattern (logstash-logback-encoder is a V2 dep)    -->
    <!-- ============================================================ -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>/var/log/orionetl/application.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>/var/log/orionetl/application.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>100MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %5p ${PID:- } --- [%15.15t] %-40.40logger{39} : [exec=%X{executionId:--}] [pipeline=%X{pipelineId:--}] [step=%X{stepName:--}] %m%n%wEx</pattern>
        </encoder>
    </appender>

    <!-- ============================================================ -->
    <!-- PROFILE-BASED ACTIVATION                                     -->
    <!-- ============================================================ -->
    <springProfile name="local,dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
        <logger name="com.elyares.etl" level="DEBUG" additivity="false">
            <appender-ref ref="CONSOLE"/>
        </logger>
    </springProfile>

    <springProfile name="prod">
        <root level="WARN">
            <appender-ref ref="FILE"/>
        </root>
        <logger name="com.elyares.etl" level="WARN" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
    </springProfile>

    <!-- Default: no profile active (tests, CI) -->
    <springProfile name="!local &amp; !dev &amp; !prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
